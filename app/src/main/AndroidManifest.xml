<?xml version="1.0" encoding="utf-8"?>
<!--
    AndroidManifest.xml — infinite-specs-xr-core (:app)

    Declares the Android XR host activity and the permissions required for
    eye-tracking (gaze) and microphone (voice transcript) inputs.

    Targets Android XR Developer Preview 4.
    See: https://developer.android.com/xr
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ── Perception layer permissions ───────────────────────────────────── -->

    <!-- Gaze / eye-tracking input (Jetpack XR) -->
    <uses-permission android:name="android.permission.EYE_TRACKING_FINE" />

    <!-- Hand tracking (Jetpack XR) -->
    <uses-permission android:name="android.permission.HAND_TRACKING" />

    <!-- Camera access for AR tracking -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- Voice transcript input -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Scene Understanding for Plane Detection (Jetpack XR) -->
    <uses-permission android:name="android.permission.SCENE_UNDERSTANDING" />
    <uses-permission android:name="android.permission.SCENE_UNDERSTANDING_COARSE" />

    <!-- Network access for local SSE bridge (loopback only in production) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- ── XR feature declarations ─────────────────────────────────────────── -->
    <uses-feature
        android:name="android.hardware.xr.headtracking"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.InfiniteSpecs">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden">
            <property
                android:name="android.window.PROPERTY_XR_ACTIVITY_START_MODE"
                android:value="XR_ACTIVITY_START_MODE_FULL_SPACE_MANAGED" />
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
